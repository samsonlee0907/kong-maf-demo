FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
FOUNDRY_MODEL=gpt-5-4-mini
FOUNDRY_OPENAI_API_VERSION=2024-10-21
FOUNDRY_RESOURCE_NAME=your-resource
FOUNDRY_PROJECT_NAME=your-project
AGENT_PORT=8080
KONG_GATEWAY_URL=http://127.0.0.1:8000
AZURE_KONG_GATEWAY_URL=
AZURE_HOSTED_AGENT_NAME=kong-maf-hosted-agent
# Use `azure-hosted` only after Azure Kong is deployed and AZURE_KONG_GATEWAY_URL is set.
# Any other value keeps the portal on the local path by default.
DEFAULT_GATEWAY_PROFILE=local-maf
